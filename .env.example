VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Edge Function 名稱。若正式專案採用不同名稱，可在 .env.local 覆寫。
VITE_ACCOUNT_LOGIN_FUNCTION=account-login
VITE_STUDENT_ACTIVATION_FUNCTION=student-activate
VITE_STUDENT_PASSWORD_RESET_FUNCTION=student-reset-password
VITE_TEACHER_REGISTRATION_FUNCTION=teacher-register
VITE_ADMIN_CREATE_PASSWORD_RESET_FUNCTION=admin-create-password-reset

# 正式部署前填入登入後的「各科選擇頁」網址。
VITE_LEARNING_SYSTEM_URL=https://example.com/learning-systems/

# 舊版設定仍受支援；若上方未設定，會使用此網址。
VITE_ENGLISH_VOCAB_URL=https://example.com/english-vocabulary/
